{
  "expo": {
    "name": "Liguster",
    "slug": "liguster-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ligusterapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,

    "ios": {
      "buildNumber": "2",
      "supportsTablet": true,
      "bundleIdentifier": "dk.liguster.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Vi bruger din position til at vise dig på kortet og finde relevante ting i nærheden af dig.",
        "NSPhotoLibraryUsageDescription": "Vi skal bruge adgang til dine billeder for at du kan uploade billeder til aktiviteter og opslag.",
        "NSPhotoLibraryAddUsageDescription": "Vi skal bruge adgang til at gemme billeder, når du downloader eller redigerer.",
        "NSCameraUsageDescription": "Vi skal bruge adgang til kameraet, hvis du vil tage et billede direkte i appen."
      }
    },

    "android": {
      "package": "dk.liguster.app",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#131921"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "READ_MEDIA_IMAGES"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            { "scheme": "ligusterapp" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#131921"
        }
      ],
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vi skal bruge adgang til dine billeder for at uploade billeder til aktiviteter og opslag.",
          "cameraPermission": "Vi skal bruge adgang til kameraet, hvis du vil tage et billede direkte i appen."
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "assetBundlePatterns": ["**/*"],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "510eb874-f1b3-4c29-9c58-4d19f0dd6272"
      },

      /* Anbefalet: flyt disse to til miljøvariabler.
         I første omgang lader jeg dem blive for kompatibilitet. */
