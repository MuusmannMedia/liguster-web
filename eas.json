{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "aab"
      }
    },
    "internal": {
      "distribution": "internal",
      "channel": "internal",
      "android": {
        "buildType": "aab"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "aab"
      }
    }
  },
  "submit": {
    "internal": {
      "android": {
        "track": "internal",
        "changesNotSentForReview": true
      }
    },
    "production": {
      "android": {
        "track": "production"
      }
    }
  }
}