{
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",

  "rewrites": [
    { "source": "/privacy",  "destination": "/index.html" },
    { "source": "/privacy/", "destination": "/index.html" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],

  "trailingSlash": true
}